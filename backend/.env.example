# Firebase Configuration
# Opción 1: Usar variable de entorno con JSON stringificado
# (Recomendado para Railway/producción)
FIREBASE_CONFIG={"type":"service_account","project_id":"whathero-73605",...}

# Opción 2: Alternativa - si usas archivo local
# (Comentar FIREBASE_CONFIG y asegurarse de que serviceAccountKey.json existe)
# serviceAccountKey.json debe estar en el mismo directorio que index.ts

# Puerto (opcional, por defecto 3000)
PORT=3000

# Modo debug (opcional)
NODE_ENV=development
# NODE_ENV=production
