<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Push Notifications (APNs). Valor 'development' en código fuente;
	     Xcode lo promueve automáticamente a 'production' al archivar para
	     TestFlight/App Store según el perfil de distribución. Un solo .p8
	     cubre ambos entornos. -->
	<key>aps-environment</key>
	<string>development</string>
</dict>
</plist>
